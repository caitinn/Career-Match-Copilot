# Google AI Studio through Google's OpenAI-compatible endpoint.
# Copy this file to .env and replace the API key value.
APP_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
APP_AI_KEY=replace_with_your_google_ai_studio_api_key
APP_AI_TEXT_MODEL=gemini-3.5-flash

# These keep the unused Atoms template modules from requiring a database locally.
MGX_IGNORE_INIT_DB=1
MGX_IGNORE_INIT_DATA=1
MGX_IGNORE_INIT_ADMIN=1

# Set to 1 in cloud deployments so API credentials are managed by the platform.
AI_CONFIG_READ_ONLY=0
